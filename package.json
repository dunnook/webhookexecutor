{
  "name": "websocket-executor",
  "displayName": "Websocket Executor",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "websocket-executor.runexecutor",
        "title": "Run Executor"
      },
      {
        "command": "websocket-executor.runOnClient",
        "title": "Run on This Client"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "robloxSessions",
          "name": "Roblox Sessions"
        }
      ]
    },
    "menus": {
      "view/item/context": [
          {
              "command": "websocket-executor.runOnClient",
              "when": "view == robloxSessions && viewItem == clientItem",
              "group": "inline"
          }
      ],
      "editor/title": [
        {
          "command": "websocket-executor.runexecutor",
          "group": "navigation"
        }
      ],
      "explorer/context": [
          {
              "command": "websocket-executor.runexecutor",
              "when": "resourceExtname == .lua || resourceExtname == .luau",
              "group": "navigation"
          }
      ]
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3"
  },
  "dependencies": {
    "express-ws": "^5.0.2"
  }
}
